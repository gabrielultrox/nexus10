{
  "name": "nexus10",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "node --watch backend/server.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "vite build",
    "lint": "eslint src",
    "format": "prettier --write src",
    "start:backend": "node backend/server.js",
    "seed:ifood-merchant": "node backend/scripts/seedIfoodMerchant.js",
    "inventory:import-csv": "node backend/scripts/importInventoryCsv.js",
    "preview": "vite preview",
    "deploy:preview": "vercel -y",
    "deploy:prod:manual": "vercel --prod -y",
    "release:auto": "node scripts/release-auto.mjs",
    "test": "vitest run",
    "firebase:login": "firebase login",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules",
    "firebase:deploy:indexes": "firebase deploy --only firestore:indexes"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2",
    "firebase": "^11.6.1",
    "firebase-admin": "^13.4.0",
    "html-to-image": "^1.11.13",
    "openai": "^6.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "firebase-tools": "^15.9.1",
    "globals": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.6.0",
    "vite": "^5.4.14",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^3.2.4"
  }
}
