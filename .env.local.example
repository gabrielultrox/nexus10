# Local overrides take precedence over .env and are not committed.

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:3001/api
VITE_LOG_LEVEL=debug
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=nexus10-local
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1
VITE_FIREBASE_USE_EMULATORS=true
VITE_FIREBASE_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Backend
NODE_ENV=dev
PORT=3001
FRONTEND_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
LOG_LEVEL=debug
SENTRY_DSN=
SENTRY_RELEASE=nexus10-local
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW_MS=60000
REDIS_URL=redis://127.0.0.1:6379
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
