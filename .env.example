# Backend/service layer - iFood
IFOOD_AUTH_BASE_URL=https://merchant-api.ifood.com.br/authentication/v1.0
IFOOD_MERCHANT_BASE_URL=https://merchant-api.ifood.com.br
IFOOD_EVENTS_POLLING_PATH=/events/v1.0/events:polling
IFOOD_EVENTS_ACK_PATH=/events/v1.0/events/acknowledgment
IFOOD_ORDER_DETAILS_PATH=/order/v1.0/orders
IFOOD_WEBHOOK_URL=https://your-backend.example.com/webhooks/ifood
IFOOD_WEBHOOK_SECRET=your_ifood_webhook_secret
IFOOD_POLLING_INTERVAL_SECONDS=30
IFOOD_WIDGET_SCRIPT_URL=https://widgets.ifood.com.br/widget.js

# Backend secure persistence
PORT=8787
FRONTEND_ORIGIN=https://your-frontend.example.com
