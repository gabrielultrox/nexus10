VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_API_BASE_URL=https://your-backend.example.com/api
VITE_FIREBASE_USE_EMULATORS=false
VITE_FIREBASE_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Backend/service layer - iFood
IFOOD_AUTH_BASE_URL=https://merchant-api.ifood.com.br/authentication/v1.0
IFOOD_MERCHANT_BASE_URL=https://merchant-api.ifood.com.br
IFOOD_EVENTS_POLLING_PATH=/events/v1.0/events:polling
IFOOD_EVENTS_ACK_PATH=/events/v1.0/events/acknowledgment
IFOOD_ORDER_DETAILS_PATH=/order/v1.0/orders
IFOOD_WEBHOOK_URL=https://your-backend.example.com/webhooks/ifood
IFOOD_WEBHOOK_SECRET=your_ifood_webhook_secret
IFOOD_POLLING_INTERVAL_SECONDS=30
IFOOD_WIDGET_SCRIPT_URL=https://widgets.ifood.com.br/widget.js

# Backend secure persistence
PORT=8787
FRONTEND_ORIGIN=https://your-frontend.example.com
CORS_PREFLIGHT_MAX_AGE_SECONDS=600
SECURITY_USER_AGENT_BLOCKLIST=sqlmap,nikto,masscan,zgrab,acunetix
RATE_LIMIT_TRUSTED_IPS=10.0.0.10,10.0.0.11
LOCAL_OPERATOR_PASSWORD=troque_esta_senha_em_producao
LOG_LEVEL=info
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_RELEASE=nexus10@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.2
MONITORING_WINDOW_MS=900000
ALERT_COOLDOWN_MS=600000
ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
ALERT_ERROR_RATE_THRESHOLD_PERCENT=5
ALERT_LATENCY_P95_THRESHOLD_MS=1000
ALERT_IFOOD_WEBHOOK_FAILURE_THRESHOLD=3
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=nexus10
REDIS_SOCKET_TIMEOUT_MS=5000
REDIS_SESSION_TTL_SECONDS=300
REDIS_MERCHANT_TTL_SECONDS=180
REDIS_PRODUCT_TTL_SECONDS=120
OPENAI_API_KEY=sua_chave_aqui
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
