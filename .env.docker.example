APP_ENV=development
NODE_ENV=development

VITE_API_BASE_URL=/api
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-nexus10.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-nexus10
VITE_FIREBASE_STORAGE_BUCKET=demo-nexus10.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:demo
VITE_APP_ENV=docker
VITE_FIREBASE_USE_EMULATORS=true
VITE_FIREBASE_FIRESTORE_EMULATOR_HOST=localhost:8080
VITE_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

FRONTEND_ORIGIN=http://localhost:3000
CORS_PREFLIGHT_MAX_AGE_SECONDS=600
SECURITY_USER_AGENT_BLOCKLIST=sqlmap,nikto,masscan,zgrab,acunetix
RATE_LIMIT_TRUSTED_IPS=10.0.0.10,10.0.0.11
LOCAL_OPERATOR_PASSWORD=0101
LOG_LEVEL=info

REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=nexus10
REDIS_SOCKET_TIMEOUT_MS=5000
REDIS_SESSION_TTL_SECONDS=300
REDIS_MERCHANT_TTL_SECONDS=180
REDIS_PRODUCT_TTL_SECONDS=120

FIREBASE_PROJECT=demo-nexus10
FIREBASE_ADMIN_PROJECT_ID=demo-nexus10
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@example.invalid
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nDEV_ONLY\n-----END PRIVATE KEY-----\n"
FIRESTORE_EMULATOR_HOST=firestore-emulator:8080
FIREBASE_AUTH_EMULATOR_HOST=firestore-emulator:9099

IFOOD_AUTH_BASE_URL=https://merchant-api.ifood.com.br/authentication/v1.0
IFOOD_MERCHANT_BASE_URL=https://merchant-api.ifood.com.br
IFOOD_EVENTS_POLLING_PATH=/events/v1.0/events:polling
IFOOD_EVENTS_ACK_PATH=/events/v1.0/events/acknowledgment
IFOOD_ORDER_DETAILS_PATH=/order/v1.0/orders
IFOOD_WEBHOOK_URL=http://localhost:3001/webhooks/ifood
IFOOD_WEBHOOK_SECRET=dev-ifood-secret
IFOOD_POLLING_INTERVAL_SECONDS=30
