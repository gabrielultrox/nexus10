{
  "$schema": "https://www.designtokens.org/tr/drafts/format/schema.json",
  "meta": {
    "name": "Nexus10 Design Tokens",
    "version": "1.0.0",
    "description": "Fonte unica de verdade para cores, tipografia, espacamento, radius, sombras e breakpoints do Nexus10."
  },
  "color": {
    "palette": {
      "red": {
        "300": { "$type": "color", "$value": "#fda4af" },
        "500": { "$type": "color", "$value": "#ef4444" },
        "700": { "$type": "color", "$value": "#b91c1c" }
      },
      "orange": {
        "300": { "$type": "color", "$value": "#fdba74" },
        "500": { "$type": "color", "$value": "#f97316" },
        "700": { "$type": "color", "$value": "#c2410c" }
      },
      "yellow": {
        "300": { "$type": "color", "$value": "#fde047" },
        "500": { "$type": "color", "$value": "#f59e0b" },
        "700": { "$type": "color", "$value": "#a16207" }
      },
      "green": {
        "300": { "$type": "color", "$value": "#86efac" },
        "500": { "$type": "color", "$value": "#22c55e" },
        "700": { "$type": "color", "$value": "#15803d" }
      },
      "blue": {
        "300": { "$type": "color", "$value": "#93c5fd" },
        "500": { "$type": "color", "$value": "#3b82f6" },
        "700": { "$type": "color", "$value": "#1d4ed8" }
      },
      "purple": {
        "300": { "$type": "color", "$value": "#d8b4fe" },
        "500": { "$type": "color", "$value": "#a855f7" },
        "700": { "$type": "color", "$value": "#7e22ce" }
      },
      "gray": {
        "50": { "$type": "color", "$value": "#fafafa" },
        "100": { "$type": "color", "$value": "#f4f4f5" },
        "200": { "$type": "color", "$value": "#e4e4e7" },
        "400": { "$type": "color", "$value": "#a1a1aa" },
        "500": { "$type": "color", "$value": "#71717a" },
        "700": { "$type": "color", "$value": "#3f3f46" },
        "900": { "$type": "color", "$value": "#18181b" },
        "950": { "$type": "color", "$value": "#0e0e10" }
      }
    },
    "semantic": {
      "success": { "$type": "color", "$value": "{color.palette.green.500}" },
      "warning": { "$type": "color", "$value": "{color.palette.yellow.500}" },
      "error": { "$type": "color", "$value": "{color.palette.red.500}" },
      "info": { "$type": "color", "$value": "{color.palette.blue.500}" }
    }
  },
  "background": {
    "page": { "$type": "color", "$value": "{color.palette.gray.950}" },
    "surface": { "$type": "color", "$value": "{color.palette.gray.900}" },
    "elevated": { "$type": "color", "$value": "#1f1f23" }
  },
  "text": {
    "primary": { "$type": "color", "$value": "{color.palette.gray.100}" },
    "secondary": { "$type": "color", "$value": "{color.palette.gray.400}" },
    "muted": { "$type": "color", "$value": "{color.palette.gray.500}" },
    "disabled": { "$type": "color", "$value": "{color.palette.gray.700}" }
  },
  "border": {
    "light": { "$type": "color", "$value": "{color.palette.gray.700}" },
    "medium": { "$type": "color", "$value": "#2e2e33" },
    "heavy": { "$type": "color", "$value": "#4b5563" }
  },
  "typography": {
    "fontFamily": {
      "display": { "$type": "fontFamily", "$value": "'Syne', 'Segoe UI', sans-serif" },
      "sans": { "$type": "fontFamily", "$value": "'DM Sans', 'Segoe UI', sans-serif" },
      "mono": { "$type": "fontFamily", "$value": "'Share Tech Mono', 'Consolas', monospace" }
    },
    "fontSize": {
      "xs": { "$type": "fontSize", "$value": "10px" },
      "sm": { "$type": "fontSize", "$value": "12px" },
      "base": { "$type": "fontSize", "$value": "14px" },
      "lg": { "$type": "fontSize", "$value": "16px" },
      "xl": { "$type": "fontSize", "$value": "20px" },
      "2xl": { "$type": "fontSize", "$value": "24px" },
      "3xl": { "$type": "fontSize", "$value": "32px" }
    },
    "fontWeight": {
      "regular": { "$type": "fontWeight", "$value": "400" },
      "medium": { "$type": "fontWeight", "$value": "500" },
      "semibold": { "$type": "fontWeight", "$value": "600" },
      "bold": { "$type": "fontWeight", "$value": "700" }
    },
    "lineHeight": {
      "tight": { "$type": "number", "$value": "1.1" },
      "normal": { "$type": "number", "$value": "1.5" },
      "relaxed": { "$type": "number", "$value": "1.7" }
    },
    "letterSpacing": {
      "tight": { "$type": "dimension", "$value": "-0.02em" },
      "normal": { "$type": "dimension", "$value": "0" },
      "wide": { "$type": "dimension", "$value": "0.08em" },
      "caps": { "$type": "dimension", "$value": "0.14em" }
    }
  },
  "spacing": {
    "scale": {
      "0": { "$type": "dimension", "$value": "2px" },
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "5": { "$type": "dimension", "$value": "24px" },
      "6": { "$type": "dimension", "$value": "32px" },
      "7": { "$type": "dimension", "$value": "48px" },
      "8": { "$type": "dimension", "$value": "64px" }
    },
    "default": {
      "paddingInline": { "$type": "dimension", "$value": "{spacing.scale.4}" },
      "paddingBlock": { "$type": "dimension", "$value": "{spacing.scale.3}" },
      "marginSection": { "$type": "dimension", "$value": "{spacing.scale.6}" },
      "gap": { "$type": "dimension", "$value": "{spacing.scale.3}" }
    }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "lg": { "$type": "dimension", "$value": "12px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "sm": { "$type": "shadow", "$value": "0 1px 2px rgba(15, 23, 42, 0.08)" },
    "md": { "$type": "shadow", "$value": "0 8px 20px rgba(15, 23, 42, 0.12)" },
    "lg": { "$type": "shadow", "$value": "0 16px 40px rgba(15, 23, 42, 0.18)" },
    "xl": { "$type": "shadow", "$value": "0 24px 64px rgba(15, 23, 42, 0.24)" }
  },
  "breakpoint": {
    "mobile": { "$type": "dimension", "$value": "480px" },
    "tablet": { "$type": "dimension", "$value": "768px" },
    "desktop": { "$type": "dimension", "$value": "1200px" }
  },
  "theme": {
    "dark": {
      "background": {
        "page": { "$type": "color", "$value": "{color.palette.gray.950}" },
        "surface": { "$type": "color", "$value": "{color.palette.gray.900}" },
        "elevated": { "$type": "color", "$value": "#1f1f23" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "{color.palette.gray.100}" },
        "secondary": { "$type": "color", "$value": "{color.palette.gray.400}" },
        "muted": { "$type": "color", "$value": "{color.palette.gray.500}" },
        "disabled": { "$type": "color", "$value": "{color.palette.gray.700}" }
      },
      "border": {
        "light": { "$type": "color", "$value": "{color.palette.gray.700}" },
        "medium": { "$type": "color", "$value": "#2e2e33" },
        "heavy": { "$type": "color", "$value": "#4b5563" }
      }
    },
    "light": {
      "background": {
        "page": { "$type": "color", "$value": "{color.palette.gray.50}" },
        "surface": { "$type": "color", "$value": "#ffffff" },
        "elevated": { "$type": "color", "$value": "{color.palette.gray.100}" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "#111113" },
        "secondary": { "$type": "color", "$value": "#52525b" },
        "muted": { "$type": "color", "$value": "{color.palette.gray.500}" },
        "disabled": { "$type": "color", "$value": "{color.palette.gray.400}" }
      },
      "border": {
        "light": { "$type": "color", "$value": "{color.palette.gray.100}" },
        "medium": { "$type": "color", "$value": "{color.palette.gray.200}" },
        "heavy": { "$type": "color", "$value": "{color.palette.gray.400}" }
      }
    },
    "amber": {
      "background": {
        "page": { "$type": "color", "$value": "#f5efe6" },
        "surface": { "$type": "color", "$value": "#fffaf2" },
        "elevated": { "$type": "color", "$value": "#efe3d1" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "#2a2118" },
        "secondary": { "$type": "color", "$value": "#625444" },
        "muted": { "$type": "color", "$value": "#8a7966" },
        "disabled": { "$type": "color", "$value": "#af9477" }
      },
      "border": {
        "light": { "$type": "color", "$value": "#e8dccb" },
        "medium": { "$type": "color", "$value": "#d7c5ad" },
        "heavy": { "$type": "color", "$value": "#b89d7c" }
      }
    }
  }
}
